{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "yabai-focus",
  "description": "Search open yabai windows and focus the selected app or window",
  "categories": [
    "Productivity",
    "System"
  ],
  "keywords": [
    "focus",
    "macos",
    "window-manager",
    "window-switcher",
    "yabai"
  ],
  "license": "MIT",
  "author": "phongndo69",
  "scripts": {
    "build": "ray build -e dist",
    "ci": "pnpm run format:check && pnpm run lsp && pnpm run lint && pnpm run build",
    "dev": "ray develop",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src --type-aware --deny-warnings",
    "lsp": "tsc --noEmit",
    "publish": "ray publish",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@raycast/api": "1.104.18"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "6.0.3"
  },
  "icon": "icon.png",
  "packageManager": "pnpm@11.4.0",
  "commands": [
    {
      "name": "focus-app",
      "title": "Focus App",
      "description": "Search open yabai windows and focus the selected app or window",
      "mode": "view"
    }
  ],
  "platforms": [
    "macOS"
  ],
  "title": "Yabai Focus"
}
